<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.TURN_SCREEN_ON" />

    <application
        android:name=".LyricsLockApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="LyricsLock"
        android:theme="@style/Theme.LyricsLock"
        android:supportsRtl="true">

        <!-- Main Settings Activity -->
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Lock Screen Activity — shown over keyguard -->
        <activity
            android:name=".ui.LockScreenActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:showForAllUsers="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.LyricsLock.LockScreen"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:launchMode="singleInstance"
            android:taskAffinity=".LockScreen" />

        <!-- Notification Listener Service -->
        <service
            android:name=".service.MediaListenerService"
            android:exported="true"
            android:label="LyricsLock Media Listener"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Lyrics Foreground Service -->
        <service
            android:name=".service.LyricsService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Cache eviction WorkManager worker — registered automatically -->

        <!-- Boot receiver to restart service -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
